{
  "name": "stroll",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "test": "node --experimental-strip-types test/seed.test.mjs",
    "ci": "npm run typecheck && npm run typecheck:server && npm run build && npm test",
    "relay": "wrangler dev --config server/wrangler.jsonc --port 8787",
    "deploy": "npm run build && wrangler deploy --config server/wrangler.jsonc"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wrangler": "^4.113.0"
  }
}
